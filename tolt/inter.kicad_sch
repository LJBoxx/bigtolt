	)
	(text_box "Hardware overcurrent should trip at about 1000a\nWe are looking for the voltage drop on the shunt\nVdr = Rshunt * current | therefore | Vdr = Rshunt * 1000\nFrom Vdr we can calculate the resistor voltage divider ratio : \nVdr = Vout = Vin * ratio | that is same as | ratio = Vin / Vdr = Vin / Rshunt * 1000 \nHere ratio of 0.1/3.3 therefore 320k and 10k \nchange 320k to 980k for 0.1mr\n"
		(exclude_from_sim no)
		(at 98.298 59.436 0)
		(size 65.278 17.78)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "dc178bc0-7e9d-4067-9691-64961c7dbfee")
	)
